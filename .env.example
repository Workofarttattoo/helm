# ============================================================================
# HELM Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# ============================================================================

# ---------- General ----------
HELM_SUITE=default
HELM_OUTPUT_DIR=/data/benchmark_output
HELM_CACHE_DIR=/data/cache
HELM_MAX_EVAL_INSTANCES=100

# ---------- Server Ports ----------
HELM_SERVER_PORT=8000
HELM_PROXY_PORT=1959
HELM_PROXY_WORKERS=4

# ---------- Model Provider API Keys ----------
# OpenAI (GPT-4, GPT-3.5, etc.)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini, PaLM)
GOOGLE_API_KEY=

# Together AI
TOGETHER_API_KEY=

# Cohere
COHERE_API_KEY=

# ---------- Optional: Perspective API (toxicity metrics) ----------
PERSPECTIVE_API_KEY=

# ---------- Optional: MongoDB Cache Backend ----------
# MONGO_URI=mongodb://localhost:27017
# MONGO_DB_NAME=helm_cache

# ---------- Optional: Scale AI (human evaluation) ----------
# SCALE_API_KEY=
# SURGE_API_KEY=

# ---------- Optional: Logging ----------
LOG_LEVEL=INFO
